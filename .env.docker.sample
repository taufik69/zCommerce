# ===== Docker Compose specific overrides =====
# Copy this file to .env (or merge with your existing .env)

# Docker Hub image settings (used when pushing the backend image)
DOCKERHUB_USERNAME=taufikislam69
IMAGE_TAG=latest

# Local MongoDB (the mongo service in docker-compose)
MONGO_USERNAME=admin
MONGO_PASSWORD=admin123
MONGO_DB=jahir

# Backend
PORT=3000
NODE_ENV=production
BASE_API=/api/v1

# These will be overridden inside docker-compose to use the mongo/redis services
# but you can still set them here for non-docker runs
DATABASE_URL=mongodb://admin:admin123@mongo:27017/jahir?authSource=admin
REDIS_URL=redis://redis:6379

# JWT
ACCESS_TOKEN_SECRET=change-me
ACCESS_TOKEN_EXPRIY=1d
REFRESH_TOKEN_SCCERET=change-me
REFRESH_TOKEN_EXPIRY=15d

# Mongo backup schedule (cron format) and retention in days
BACKUP_CRON=0 2 * * *
BACKUP_RETENTION_DAYS=7

# ----- The rest of your app envs (cloudinary, sslcommerz, mailer, etc) -----
# Copy them over from your existing .env
